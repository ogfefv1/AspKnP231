<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AspKnP231</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AspKnP231.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">AspKnP231</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-house header-icon"></i></a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy"><i class="bi bi-shield-check header-icon"></i></a>
                        </li>
                        <li class="nav-item" title="Вступ до ASP.NET Core MVC">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Intro"><i class="bi bi-play-circle header-icon"></i></a>
                        </li>


                        <li class="nav-item" title="Розмітковий синтаксис Razor">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Razor"><i class="bi bi-at header-icon-big"></i></a>
                        </li>
                        <li class="nav-item" title="Моделі в ASP">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Models"><i class="bi bi-grid header-icon"></i></a>
                        </li>

                        <li class="nav-item" title="Робота з залежностями: IoC, DI, DIP">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="IoC"><i class="bi bi-box-arrow-in-down-right header-icon"></i></a>
                        </li>

                        <li class="nav-item" title="Робота з Middleware">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Middleware"><i class="bi bi-hdd-rack bi-rot-90 header-icon"></i></a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - AspKnP231 - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>